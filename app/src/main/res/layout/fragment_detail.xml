<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_background">

    <!-- 상단 헤더 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="18dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="14dp">
    </RelativeLayout>

    <!-- 회의 정보 카드 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardMeetingInfo"
        android:layout_width="match_parent"
        android:layout_height="125dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="18dp"
        app:cardBackgroundColor="@color/color_surface"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/color_text_primary"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="16dp"
            android:paddingEnd="18dp"
            android:paddingBottom="16dp"
            android:background="@color/gray_100"
            >

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="제목"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="|"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="(회의명)"
                    android:textColor="@color/color_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btnEditMeetingInfo"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="회의 정보 수정"
                    android:padding="5dp"
                    android:src="@drawable/ic_pencil"
                    app:tint="@color/color_text_primary" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:background="@color/color_text_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="날짜"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="|"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/meetingDate"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="2025.05.12"
                    android:textColor="@color/color_text_primary"
                    android:textSize="17sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="0dp"
                android:layout_marginBottom="0dp"
                android:background="@color/color_text_primary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="44dp"
                    android:layout_height="wrap_content"
                    android:text="시간"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="|"
                    android:textColor="@color/color_text_secondary"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/meetingTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="오후 12:30"
                    android:textColor="@color/color_text_primary"
                    android:textSize="17sp" />
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 탭 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="52dp"
        android:layout_marginEnd="52dp"
        android:layout_marginBottom="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabSummary"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="요약"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/color_primary"
            app:cornerRadius="0dp"
            app:strokeColor="@color/color_text_primary"
            app:strokeWidth="1dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/tabFiles"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginStart="-1dp"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="0dp"
            android:padding="0dp"
            android:text="파일"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/white"
            app:cornerRadius="0dp"
            app:strokeColor="@color/color_text_primary"
            app:strokeWidth="1dp" />
    </LinearLayout>

    <!-- 요약 -->
    <ScrollView
        android:id="@+id/summaryScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="2dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- 회의 요약 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSummary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/color_text_primary"
                app:strokeWidth="1dp"

                >

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:background="@color/gray_100"
                    >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="회의 요약"
                            android:textColor="@color/color_text_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />

                        <ImageButton
                            android:id="@+id/btnEditSummary"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="회의 요약 수정"
                            android:padding="5dp"
                            android:src="@drawable/ic_pencil"
                            app:tint="@color/color_text_primary" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/color_text_primary" />

                    <TextView
                        android:id="@+id/summaryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="4dp"
                        android:text="—"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 결정 사항 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDecisions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/color_text_primary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:background="@color/gray_100"
                    >

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="결정 사항"
                        android:textColor="@color/color_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/color_text_primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/decisionText1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=". 결정 사항 내용 1"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp" />

                        <ImageButton
                            android:id="@+id/btnEditDecision1"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="결정 사항 1 수정"
                            android:padding="5dp"
                            android:src="@drawable/ic_pencil"
                            app:tint="@color/color_text_primary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/decisionText2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text=". 결정 사항 내용 2"
                            android:textColor="@color/color_text_primary"
                            android:textSize="15sp" />

                        <ImageButton
                            android:id="@+id/btnEditDecision2"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="결정 사항 2 수정"
                            android:padding="5dp"
                            android:src="@drawable/ic_pencil"
                            app:tint="@color/color_text_primary" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 할 일 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/color_surface"
                app:cardCornerRadius="22dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/color_text_primary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp"
                    android:background="@color/gray_100">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="할 일"
                        android:textColor="@color/color_text_primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/color_text_primary" />

                    <!-- 할 일 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="wrap_content"
                                android:text="제목"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/taskTitle1"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="할 일 첫번째"
                                android:textColor="@color/color_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/btnEditAction1"
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="할 일 1 수정"
                                android:padding="5dp"
                                android:src="@drawable/ic_pencil"
                                app:tint="@color/color_text_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="담당자"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/taskOwner1"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="(담당자)"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="34dp"
                                android:layout_height="wrap_content"
                                android:text="마감"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/taskDeadline1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="2025.05.12"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/color_text_primary" />

                    <!-- 할 일 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="wrap_content"
                                android:text="제목"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/taskTitle2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="할 일 두번째"
                                android:textColor="@color/color_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/btnEditAction2"
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="할 일 2 수정"
                                android:padding="5dp"
                                android:src="@drawable/ic_pencil"
                                app:tint="@color/color_text_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="담당자"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/taskOwner2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="(담당자)"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="34dp"
                                android:layout_height="wrap_content"
                                android:text="마감"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/taskDeadline2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="2025.05.12"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="@color/color_text_primary" />

                    <!-- 할 일 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="wrap_content"
                                android:text="제목"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="15sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="18sp" />

                            <TextView
                                android:id="@+id/taskTitle3"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="할 일 세번째"
                                android:textColor="@color/color_text_primary"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <ImageButton
                                android:id="@+id/btnEditAction3"
                                android:layout_width="34dp"
                                android:layout_height="34dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="할 일 3 수정"
                                android:padding="5dp"
                                android:src="@drawable/ic_pencil"
                                app:tint="@color/color_text_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="담당자"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/taskOwner3"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:layout_weight="1"
                                android:text="(담당자)"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="34dp"
                                android:layout_height="wrap_content"
                                android:text="마감"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="|"
                                android:textColor="@color/color_text_secondary"
                                android:textSize="16sp" />

                            <TextView
                                android:id="@+id/taskDeadline3"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:text="2025.05.12"
                                android:textColor="@color/color_text_primary"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <Button
                android:id="@+id/btnDeleteMeeting"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:text="삭제"
                android:textSize="10sp"
                android:padding="4dp"
                android:src="@drawable/ic_delete"
                android:layout_gravity="center"
                android:backgroundTint="@color/gray_100"
                android:textColor="@color/color_text_primary"
                style="@style/Widget.MaterialComponents.Button"
                android:textAllCaps="false"
                app:backgroundTint="@color/color_primary"
                app:cornerRadius="0dp"
                app:strokeColor="@color/color_text_primary"
                app:strokeWidth="1dp"
                />

                <!--
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                -->
        </LinearLayout>
    </ScrollView>

    <!-- 파일 리스트 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/fileRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="20dp"
        android:paddingTop="6dp"
        android:paddingEnd="20dp"
        android:paddingBottom="20dp"
        android:visibility="gone" />

</LinearLayout>