<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.A20260310.BottomNavigationView" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
    </style>

    <!-- MaterialButton: tint 기반 배경(상태별) — drawable+transparent는 흰 배경으로 보일 수 있음 -->
    <style name="AppButtonPrimary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/button_primary_background_tint</item>
        <item name="android:textColor">@color/button_primary_text</item>
        <item name="rippleColor">@color/gray_400</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:minHeight">48dp</item>
    </style>

    <style name="RectButton">
        <item name="cornerRadius">0dp</item>
    </style>

    <style name="MoaCard">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/moa_line</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

    <style name="MoaCardContent">
        <item name="android:padding">16dp</item>
        <item name="android:orientation">vertical</item>
    </style>

    <style name="MoaCardTitle">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="MoaCardBody">
        <item name="android:layout_marginTop">8dp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

</resources>
